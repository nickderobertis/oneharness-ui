{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bash \"$CLAUDE_PROJECT_DIR/scripts/session-setup.sh\"",
            "timeout": 180,
            "type": "command"
          }
        ],
        "matcher": "startup|resume"
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(just --list)",
      "Bash(just bootstrap)",
      "Bash(just check)",
      "Bash(just gate)",
      "Bash(just test)",
      "Bash(just test-e2e)",
      "Bash(just lint)",
      "Bash(just format)",
      "Bash(just upgrade)",
      "Bash(just build)",
      "Bash(just setup-llmlint)",
      "Bash(just session-setup)",
      "Bash(just lint-llm)",
      "Bash(just lint-llm-diff)",
      "Bash(just lint-llm-validate)",
      "Bash(git status --short)",
      "Bash(git diff)",
      "Bash(git diff --check)",
      "Bash(git log --oneline -10)"
    ],
    "deny": []
  }
}
