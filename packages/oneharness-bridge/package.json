{
  "name": "@oneharness-ui/bridge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "oneharness-ui-bridge": "./src/cli.ts"
  },
  "scripts": {
    "build": "bun build src/cli.ts --target=bun --outdir=dist",
    "test": "bun test --coverage src test",
    "typecheck": "tsc -p tsconfig.json",
    "lint": "biome check src test package.json tsconfig.json project.json",
    "format:check": "biome format src test package.json tsconfig.json project.json"
  },
  "dependencies": {
    "@oneharness/sdk": "0.3.23",
    "@oneharness-ui/ipc-contract": "workspace:*",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "7.0.2"
  }
}
