{
  "$schema": "https://biomejs.dev/schemas/2.5.4/schema.json",
  "files": {
    "includes": [
      "**",
      "!!apps/desktop-shell/binaries",
      "!!apps/desktop-shell/gen",
      "!!**/.cache",
      "!!**/.next",
      "!!**/.nx",
      "!!**/coverage",
      "!!**/dist",
      "!!**/node_modules",
      "!!**/out",
      "!!**/playwright-report",
      "!!**/test-results",
      "!!**/target"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "lineWidth": 100
  },
  "javascript": {
    "formatter": { "quoteStyle": "double", "semicolons": "always" }
  },
  "css": {
    "parser": { "tailwindDirectives": true }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "a11y": { "preset": "none" },
      "correctness": {
        "noUnusedImports": "error",
        "noUnusedVariables": "error",
        "useExhaustiveDependencies": "error",
        "useHookAtTopLevel": "error"
      },
      "security": { "noDangerouslySetInnerHtml": "error" },
      "style": {
        "noRestrictedImports": {
          "level": "error",
          "options": {
            "patterns": [
              {
                "group": ["@/features/*/*"],
                "message": "Import another feature through its public index."
              }
            ]
          }
        }
      },
      "suspicious": { "noExplicitAny": "error" }
    }
  },
  "overrides": [
    {
      "includes": ["apps/conversation-ui/src/components/**"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": ["@/features/*", "@/features/*/*"],
                    "message": "Shared UI cannot depend on a feature."
                  }
                ]
              }
            }
          }
        }
      }
    }
  ],
  "assist": {
    "actions": { "source": { "organizeImports": "on" } }
  }
}
